# ─── Frontend (Vite) ───
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_key

# URL da API de pagamentos em PRODUÇÃO (obrigatório no build de produção)
# Ex: https://estelite-api.up.railway.app
VITE_API_URL=

VITE_MP_PUBLIC_KEY=

# ─── Backend (server.js) — Railway / Render ───
PORT=3001

MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=

# Aliases aceitos pelo server.js
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# URL pública do site (Lovable / domínio customizado)
FRONTEND_URL=https://estelite.lovable.app

# Origens extras permitidas no CORS (separadas por vírgula)
# CORS_ORIGINS=https://www.seudominio.com,https://seudominio.com
